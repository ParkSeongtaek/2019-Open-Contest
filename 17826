#include<iostream>
#include<vector>
#include<queue>
#include<algorithm>
using namespace std;

int main() {

	ios_base::sync_with_stdio(false);
	cin.tie(NULL);


	vector<int> num(50);
	int my;
	int cnt = 1;
	for (int i = 0; i < 50; i++) {
		cin >> num[i];
	}
	cin >> my;

	for (; cnt<=50 && num[cnt-1]>my; cnt++);
	if (cnt <= 5) {
		cout << "A+";
	}
	else if(cnt <= 15) {
		cout << "A0";
	}
	else if(cnt <= 30) {
		cout << "B+";
	}
	else if(cnt <= 35) {
		cout << "B0";
	}
	else if(cnt <= 45) {
		cout << "C+";
	}
	else if(cnt <= 48) {
		cout << "C0";
	}
	else if(cnt <= 50) {
		cout << "F";
	}
	


}

